      "url_columns": ["source_url"],
      "enum_columns": {
        "quarter": ["2024-Q4", "2025-Q1", "2025-Q2", "2025-Q3"]
      },
      "fk_columns": {
        "pilot_id": {
          "target_dataset": "data/plans/pilot-lpas.csv",
          "target_column": "pilot_id"
        }
      }
    },
    {
      "path": "data/issues/lpa-issue-incidence.csv",
      "required_columns": [
        "pilot_id", "lpa_name", "total_linked_issues", "high_severity_issues",
        "process_stage_coverage", "primary_risk_stage", "last_reviewed", "notes"
      ],
      "date_columns": ["last_reviewed"],
      "enum_columns": {
        "primary_risk_stage": ["Pre-application", "Validation", "Consultation", "Committee", "Legal Agreements", "Condition Discharge"]
      },
      "fk_columns": {
        "pilot_id": {
          "target_dataset": "data/plans/pilot-lpas.csv",
          "target_column": "pilot_id"
        }
      }
    },
    {
      "path": "data/issues/recommendation-status.csv",
      "required_columns": [
        "recommendation_id", "submission_status", "next_action"
      ],
      "id_column": "recommendation_id",
      "enum_columns": {
        "submission_status": ["Not submitted", "Submitted", "Response received", "Under review", "Adopted", "Rejected"]
      },
      "fk_columns": {
        "recommendation_id": {
          "target_dataset": "data/issues/recommendations.csv",
          "target_column": "recommendation_id"
        }
      }
    },
    {
      "path": "data/evidence/appeal-decisions.csv",
      "required_columns": [
        "appeal_id", "pins_reference", "appeal_type", "lpa",
        "decision_date", "outcome", "linked_issue", "policy_cited",
        "inspector_finding", "source_url", "retrieved_at", "notes"
      ],
      "id_column": "appeal_id",
      "date_columns": ["decision_date", "retrieved_at"],
      "url_columns": ["source_url"],
      "enum_columns": {
