    {
      "path": "data/issues/bottleneck-heatmap.csv",
      "required_columns": [
        "stage_id", "process_stage", "pathway", "median_delay_weeks",
        "delay_driver", "frequency", "severity", "linked_issues",
        "source_evidence", "notes"
      ],
      "id_column": "stage_id",
      "enum_columns": {
        "process_stage": ["Pre-application", "Validation", "Consultation", "Committee", "Legal Agreements", "Condition Discharge"],
        "pathway": ["Housing", "Commercial", "Infrastructure", "Mixed"],
        "frequency": ["High", "Medium", "Low"],
        "severity": ["High", "Medium", "Low"]
      }
    },
    {
      "path": "data/plans/lpa-data-quality.csv",
      "required_columns": [
        "pilot_id", "lpa_name", "data_quality_tier", "coverage_score",
        "evidence_type_mix", "last_reviewed", "notes"
      ],
      "id_column": "pilot_id",
      "date_columns": ["last_reviewed"],
      "enum_columns": {
        "data_quality_tier": ["A", "B", "C"]
      },
      "fk_columns": {
        "pilot_id": {
          "target_dataset": "data/plans/pilot-lpas.csv",
          "target_column": "pilot_id"
        }
      }
    },
    {
      "path": "data/evidence/lpa-quarterly-trends.csv",
      "required_columns": [
        "pilot_id", "lpa_name", "quarter", "major_in_time_pct",
